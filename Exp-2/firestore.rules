rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // Product Schema Validation
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'imageUrl', 'category']) &&
             data.keys().size() >= 4 &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.imageUrl is string && data.imageUrl.size() <= 500 &&
             data.category is string && data.category.size() <= 50;
    }

    // Cart Item Schema Validation
    function isValidCartItem(data) {
      return data.keys().hasAll(['productId', 'quantity', 'addedAt']) &&
             data.keys().size() == 3 &&
             data.productId is string && data.productId.size() <= 128 &&
             data.quantity is number && data.quantity >= 1 &&
             data.addedAt is string; // Simplified for this example, ideally use timestamp
    }

    // Products Collection: Anyone can read, only system/admin (here we allow for seeding)
    match /products/{productId} {
      allow list: if true;
      allow get: if isValidId(productId);
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
      allow update, delete: if false; 
    }

    // User Cart Subcollection
    match /users/{userId}/cart/{itemId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(itemId);
      allow create: if isOwner(userId) && isValidId(itemId) && isValidCartItem(incoming());
      allow update: if isOwner(userId) && isValidId(itemId) && isValidCartItem(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['quantity']);
      allow delete: if isOwner(userId) && isValidId(itemId);
    }
    
    // Internal Test Collection
    match /test/connection {
      allow get: if true;
    }
  }
}
