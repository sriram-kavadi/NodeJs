{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the catalog",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "price", "imageUrl"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "An item in a user's shopping cart",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "quantity"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Catalog of products"
    },
    "users/{userId}/cart": {
      "schema": "CartItem",
      "description": "User's shopping cart items"
    }
  }
}
